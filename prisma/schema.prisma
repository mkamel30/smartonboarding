generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────── الأدوار ──────────
enum UserRole {
  ADMIN
  BRANCH_SALES
  BRANCH_SUPERVISOR
  BRANCH_MANAGER
  BRANCH_MGMT          // إدارة الفروع (المركزية)
  SALES_MGMT           // إدارة المبيعات
  OPERATIONS
  MANAGEMENT
}

// ────────── الفروع ──────────
model Branch {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  governorate String
  address     String?
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  requests    OnboardingRequest[]
  batches     ShipmentBatch[]
}

// ────────── المستخدمون ──────────
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  fullName     String
  role         UserRole
  isActive     Boolean  @default(true)
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])

  // MFA (TOTP)
  mfaEnabled   Boolean  @default(false)
  mfaSecret    String?              // TOTP secret (encrypted)
  mfaVerified  Boolean  @default(false) // تم التفعيل والتحقق بنجاح

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdRequests   OnboardingRequest[] @relation("CreatedBy")
  historyEntries    StageHistory[]      @relation("ChangedByUser")
  notifications     Notification[]
  sentBatches       ShipmentBatch[]     @relation("BatchSender")
  receivedBatches   ShipmentBatch[]     @relation("BatchReceiver")
}

// ────────── طلبات التهيئة ──────────
model OnboardingRequest {
  id                   String   @id @default(cuid())
  merchantNameAr       String
  merchantNameEn       String?
  governorate          String?
  activityType         String?
  serviceType          String?
  customerCode         String?
  machineType          String?
  responsiblePerson    String?
  address              String?
  phone                String?
  email                String?

  // أرقام الهوية
  commercialRegistryNo String?
  taxCardNo            String?
  licenseNo            String?
  nationalIdNo         String?

  // بيانات بنكية
  iban                 String?
  bankName             String?

  // بيانات فنية
  machineCode          String?
  machineSerial        String?
  cardsAcceptance      String?

  // تعاقد
  contractDate         String?
  damanCode            String?

  // ربط بالفرع والمستخدم المُنشئ
  branchId             String
  branch               Branch   @relation(fields: [branchId], references: [id])
  createdById          String
  createdBy            User     @relation("CreatedBy", fields: [createdById], references: [id])

  // Workflow
  stage                String   @default("Branch Management Review")
  status               String   @default("Pending")
  assignedTo           String   @default("System")
  ownerRole            String   @default("BRANCH_MGMT")

  // نوع KYC (يحدده إدارة الفروع)
  kycType              String?  // "KYC" | "LKYC"

  // تتبع مراحل الموافقة
  branchMgmtApprovedAt DateTime?
  branchMgmtApprovedBy String?
  salesMgmtApprovedAt  DateTime?
  salesMgmtApprovedBy  String?
  salesMgmtFormFileId  String?   // ملف النموذج الموقع والمختوم من إدارة المبيعات

  // تتبع البنك
  sentToBankAt         DateTime?
  bankResponseAt       DateTime?
  bankResponse         String?   // "approved" | "rejected" | "modification"

  // تأكيد التشغيل
  softwareActivated    Boolean  @default(false)
  activatedAt          DateTime?
  activatedById        String?

  // باتش الشحن
  shipmentBatchId      String?
  shipmentBatch        ShipmentBatch? @relation(fields: [shipmentBatchId], references: [id])
  documentsSentAt      DateTime?
  waybillNumber        String?
  documentsReceivedAt  DateTime?
  documentsReceivedBy  String?

  // مرحلة الإرجاع (لتحديد وجهة العودة بعد التعديل)
  returnToStage        String?   // المرحلة التي يرجع إليها بعد تعديل الفرع

  // SLA
  slaStartDate         DateTime @default(now())
  slaTargetDays        Int      @default(3)

  // Post-approval
  merchantId           String?

  // Drive
  driveFolderId        String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  history              StageHistory[]
  notifications        Notification[]
}

// ────────── باتشات شحن المستندات ──────────
model ShipmentBatch {
  id              String   @id @default(cuid())
  batchNumber     String   @unique          // رقم تسلسلي للباتش
  waybillNumber   String                    // رقم بوليصة الشحن
  waybillFileId   String?                   // scan البوليصة على Drive
  waybillFolderId String?                   // فولدر البواليص على Drive

  senderBranchId  String
  senderBranch    Branch   @relation(fields: [senderBranchId], references: [id])
  senderUserId    String
  senderUser      User     @relation("BatchSender", fields: [senderUserId], references: [id])

  receivedAt      DateTime?
  receivedById    String?
  receivedBy      User?    @relation("BatchReceiver", fields: [receivedById], references: [id])

  status          String   @default("Shipped") // "Shipped" | "Received"
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requests        OnboardingRequest[]
}

// ────────── التنبيهات ──────────
model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  type        String   // نوع التنبيه
  title       String
  message     String

  requestId   String?
  request     OnboardingRequest? @relation(fields: [requestId], references: [id])

  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ────────── سجل التدقيق ──────────
model StageHistory {
  id            String   @id @default(cuid())
  requestId     String
  fromStage     String
  toStage       String
  status        String
  changedById   String
  comment       String?
  createdAt     DateTime @default(now())

  request       OnboardingRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  changedByUser User              @relation("ChangedByUser", fields: [changedById], references: [id])
}
